)

(define "FinishPendingStepOver"
    (if (= (var "StepOverPending") 21)
        ("FinishOrCancelStepOver" "FinishFirstTam2StepOver")
        (if (or {
                (= (var "StepOverPending") 106)
                (= (var "StepOverPending") 107)
