            ("SlideCapture" (directions {Forward Backward} of:All))
            ("StepModeChoice" (sites Direction from:(from) (directions {Forward Backward} of:All) stop:(is Occupied (to)) stopIncluded:True) 9 ("SlideStepOverFinish" (directions {Forward Backward} of:All)))
            ("StepOverSlide" (directions {Forward Backward} of:All))
            ("StepCapture" (directions {Leftward Rightward} of:All))
            ("StepModeChoice" (sites Direction from:(from) (directions {Leftward Rightward} of:All) distance:1) 14 "LineStepOverFinish")
            ("StepOverFixed" (directions {Leftward Rightward} of:All) 1 1)
            ("TwoStepNoHop" (directions {Leftward Rightward} of:All))
            ("StepOverFixed" (directions {Leftward Rightward} of:All) 2 1)
