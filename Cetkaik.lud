            "FinishStepOverDirectedSlide"
            (if (= (var "StepOverPending") 116)
                "FinishStepOverDirectedMaun1Hue"
                "FinishStepOverByPiece"
            )
        )
    )
)

(define "StepOverFixed"
    (if False (move Pass))
)

(define "StepOverSlide"
    (if False (move Pass))
)

