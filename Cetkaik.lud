(define "SameColourUai1TwoKauk2s"
    (or {
        (>= (+ (+ ("One" ("HC" #1 "LudecletiUai1")) ("CapTwo" ("HC" #1 "LudecletiKauk2"))) ("HC" #1 "LudecletiIo")) 3)
        (>= (+ (+ ("One" ("HC" #1 "DelunletiUai1")) ("CapTwo" ("HC" #1 "DelunletiKauk2"))) ("HC" #1 "DelunletiIo")) 3)
