(define "IsTam2At"
    (= (what at:#1) (id "Tam2" Neutral))
)

(define "IsFriendAt"
    (= (who at:#1) (mover))
)

(define "IsEnemyAt"
    (is Enemy (who at:#1))
)

(define "EnemyHueUai1Sites"
    (intersection
        (sites Occupied by:Enemy components:{"LudecletiUai1" "DelunletiUai1"})
        (union (sites "TamHue") (sites Around (where "Tam2" Neutral) All))
    )
)

(define "IsProtectedEnemyAt"
    (and {
        ("IsEnemyAt" #1)
        (> (count Sites in:(intersection (sites Around #1 All) "EnemyHueUai1Sites")) 0)
    })
)

(define "CanLandAt"
    (and {
        (not ("IsFriendAt" #1))
        (not ("IsTam2At" #1))
        (not ("IsProtectedEnemyAt" #1))
    })
)

(define "NoBoardStacks"
    (= 0 (count Sites in:(forEach (sites Board) if:(> (size Stack at:(site)) 1))))
)

(define "BoardStacksAllowed"
    (or {
        (> (var "StepOverPending") 0)
        "NoBoardStacks"
    })
)

(define "CapturePiece"
    (apply
        (if ("IsEnemyAt" (to))
            (and {
                (add
                    (piece (mapEntry "Captured" (what at:(to))))
                    (to (mapEntry "Where" (what at:(to))))
                )
                (remove (to))
            })
        )
    )
)

(define "ClearLastTam2Move"
    (set Var "LastTam2Mover" 0)
)

(define "InitialiseControlVars"
    (and {
        (set Var "StarterChosen" 0)
        (set Var "StepOverPending" 0)
        (set Var "StepOverTurn" (- 0 1))
        (set Var "StepOverOrigin" (- 0 1))
        (set Var "StepOverVia" (- 0 1))
        (set Var "StepOverDirection" (- 0 1))
        (set Var "StepOverPips" (- 0 1))
        (set Var "StepOverMode" 0)
        (set Var "StepOverArmedOrigin" (- 0 1))
        (set Var "DeclarationPending" 0)
        (set Var "LastTam2Mover" 0)
        (set Var "Tam2Pending" 0)
        (set Var "Tam2Futile" 0)
        (set Var "KnownRoleScoreP1" 0)
        (set Var "KnownRoleScoreP2" 0)
        (set Var "SituationRoleScoreP1" 0)
        (set Var "SituationRoleScoreP2" 0)
        (set Var "NewSituationRoleP1" 0)
        (set Var "NewSituationRoleP2" 0)
        (set Var "SeasonRate" 1)
        (set Var "PendingClaim" 0)
        (set Var "ScoreTransfer" 0)
        (set Var "StartNextSeason" 0)
        (if (< (var "Season") 0) (set Var "Season" 0))
    })
)

(define "AfterStandardMove"
    (and {
        "ClearLastTam2Move"
        "ClearStepOverMode"
    })
)

(define "NormalMoveMode"
    (= (var "StepOverMode") 0)
)

(define "ArmedStepOverMode"
    (= (var "StepOverMode") 1)
)

(define "ClearStepOverMode"
    (and {
        (set Var "StepOverMode" 0)
        (set Var "StepOverArmedOrigin" (- 0 1))
    })
)

(define "ArmStepOver"
    (move Select
        (from (sites Occupied by:Mover container:"Board") if:(and {
            "NormalMoveMode"
            (!= (var "StepOverTurn") (count Turns))
            (>
                (count Sites in:(intersection
                    (sites Direction from:(from) All stop:(is Occupied (to)) stopIncluded:True)
                    (sites Occupied by:All)
                ))
                0
            )
        }))
        (then
            (and {
                (set Var "StepOverMode" 1)
                (set Var "StepOverArmedOrigin" (last From))
                (moveAgain)
            })
        )
    )
)

(define "CancelArmedStepOver"
    (move Select
        (from (var "StepOverArmedOrigin"))
        (then (set Var "StepOverMode" 2))
    )
)

(define "AddSituationRoleMover"
    (if (is Mover P1)
        (and {
            (set Var "SituationRoleScoreP1" (+ (var "SituationRoleScoreP1") #1))
            (set Var "NewSituationRoleP1" 1)
        })
        (and {
            (set Var "SituationRoleScoreP2" (+ (var "SituationRoleScoreP2") #1))
            (set Var "NewSituationRoleP2" 1)
        })
    )
)

(define "WaterEntryStartInWater"
    (if (= (last From) (var "StepOverVia"))
        (is In (var "StepOverOrigin") (sites "TamNua"))
        (is In (last From) (sites "TamNua"))
    )
)

(define "WithWaterEntryCheck"
    (or {
        (do
            #1
            ifAfterwards:(not ("NeedsWaterRoll"))
        )
        (do
            (roll)
            next:#1
            ifAfterwards:(and {("NeedsWaterRoll") (>= (count Pips) 3)})
        )
        (do
            (roll)
            next:(if (> (var "StepOverPending") 0) "CancelStepOver" (move Pass))
            ifAfterwards:(and {(< (count Pips) 3) (can Move (do #1 ifAfterwards:"NeedsWaterRoll"))})
        )
    })
)

(define "FirstStickSite"
    (+ (count Cells) (+ (count Sites in:(sites Hand P1)) (count Sites in:(sites Hand P2))))
)

(define "ThrowSticks"
    (do
        (roll)
        next:(move Select
            (from (sites {("FirstStickSite")}))
            (then #1)
        )
    )
)

(define "ThrowStepOverSticks"
    ("ThrowSticks"
        (and {
            (set Var "StepOverPips" (count Pips))
            (moveAgain)
        })
    )
)

(define "ChooseStarter"
    (if (<= (var "StarterStage") 0)
        ("ThrowSticks"
            (and {
                "InitialiseControlVars"
                (set Var "StarterP1" (count Pips))
                (set Var "StarterStage" 1)
                (set NextPlayer (player 2))
            })
        )
        ("ThrowSticks"
            (if (> (var "StarterP1") (count Pips))
                (and {
                    (set Var "StarterChosen" 1)
                    (set Var "StarterStage" 0)
                    (set NextPlayer (player 1))
                })
                (if (< (var "StarterP1") (count Pips))
                    (and {
                        (set Var "StarterChosen" 1)
                        (set Var "StarterStage" 0)
                        (set NextPlayer (player 2))
                    })
                    (and {
                        (set Var "StarterStage" 0)
                        (set NextPlayer (player 1))
                    })
                )
            )
        )
    )
)

(define "TwoStepOrHop"
    (if "NormalMoveMode"
        ("WithWaterEntryCheck"
            (move Slide
                #1
                (between (exact 2) if:True)
                (to if:("CanLandAt" (to)) "CapturePiece")
                (then "AfterStandardMove")
            )
        )
    )
)

(define "StepCapture"
    (if "NormalMoveMode"
        ("WithWaterEntryCheck"
            (move Step
                #1
                (to if:("CanLandAt" (to)) "CapturePiece")
                (then "AfterStandardMove")
            )
        )
    )
)

(define "SlideCapture"
    (if "NormalMoveMode"
        ("WithWaterEntryCheck"
            (move
                (from (from))
                (to
                    (sites Direction from:(from) #1)
                    if:(and {
                        ("CanLandAt" (to))
                        (= 0 (count Sites in:(intersection (sites Between from:(from) to:(to)) (sites Occupied by:All))))
                    })
                    "CapturePiece"
                )
                (then "AfterStandardMove")
            )
        )
    )
)

(define "SlideCaptureMinDistance"
    (if "NormalMoveMode"
        ("WithWaterEntryCheck"
            (move
                (from (from))
                (to
                    (sites Direction from:(from) #1)
                    if:(and {
                        (>= (count Steps (from) (to)) #2)
                        ("CanLandAt" (to))
                        (= 0 (count Sites in:(intersection (sites Between from:(from) to:(to)) (sites Occupied by:All))))
                    })
                    "CapturePiece"
                )
                (then "AfterStandardMove")
            )
        )
    )
)

(define "TwoStepNoHop"
    (if "NormalMoveMode"
        ("WithWaterEntryCheck"
            (move Slide
                #1
                (between (exact 2) if:(is Empty (between)))
                (to if:("CanLandAt" (to)) "CapturePiece")
                (then "AfterStandardMove")
            )
        )
    )
)

(define "SteppedTam2Penalty"
    (apply
        (if (= (what at:(between)) (id "Tam2" Neutral))
            ("AddSituationRoleMover" -5)
        )
    )
)

(define "ActualStepStart"
    (move
        (from (from) if:(and {"ArmedStepOverMode" (= (from) (var "StepOverArmedOrigin"))}))
        (to #1 if:(and {
            (!= (var "StepOverTurn") (count Turns))
            (is Occupied (to))
            "HasAnyStepOverFinishFromVia"
        }))
        stack:True
        (then
            (and {
                (set Var "StepOverOrigin" (last From))
                (set Var "StepOverVia" (last To))
                (set Var "StepOverPending" #2)
                (set Var "StepOverTurn" (count Turns))
                "ClearStepOverMode"
                (if (= (what at:(last To)) (id "Tam2" Neutral)) ("AddSituationRoleMover" -5))
                (moveAgain)
            })
        )
    )
)

(define "StepModeChoice"
    ("ActualStepStart" #1 #2 #3)
)

(define "MovingPieceIsNuak1"
    (or {
        (= (what at:(from)) (id "LudecletiNuak1" Mover))
        (= (what at:(from)) (id "DelunletiNuak1" Mover))
    })
)

(define "MovingPieceIsKauk2"
    (or {
        (= (what at:(from)) (id "LudecletiKauk2" Mover))
        (= (what at:(from)) (id "DelunletiKauk2" Mover))
    })
)

(define "MovingPieceIsGua2"
    (or {
        (= (what at:(from)) (id "LudecletiGua2" Mover))
        (= (what at:(from)) (id "DelunletiGua2" Mover))
    })
)

(define "MovingPieceIsKaun1"
    (or {
        (= (what at:(from)) (id "LudecletiKaun1" Mover))
        (= (what at:(from)) (id "DelunletiKaun1" Mover))
    })
)

(define "MovingPieceIsDau2"
    (or {
        (= (what at:(from)) (id "LudecletiDau2" Mover))
        (= (what at:(from)) (id "DelunletiDau2" Mover))
    })
)

(define "MovingPieceIsMaun1"
    (or {
        (= (what at:(from)) (id "LudecletiMaun1" Mover))
        (= (what at:(from)) (id "DelunletiMaun1" Mover))
    })
)

(define "MovingPieceIsKua2"
    (or {
        (= (what at:(from)) (id "LudecletiKua2" Mover))
        (= (what at:(from)) (id "DelunletiKua2" Mover))
    })
)

(define "MovingPieceIsTuk2"
    (or {
        (= (what at:(from)) (id "LudecletiTuk2" Mover))
        (= (what at:(from)) (id "DelunletiTuk2" Mover))
    })
)

(define "MovingPieceIsUai1"
    (or {
        (= (what at:(from)) (id "LudecletiUai1" Mover))
        (= (what at:(from)) (id "DelunletiUai1" Mover))
    })
)

(define "MovingPieceIsIo"
    (or {
        (= (what at:(from)) (id "LudecletiIo" Mover))
        (= (what at:(from)) (id "DelunletiIo" Mover))
    })
)

(define "StepOverPiece"
    (what at:(var "StepOverVia") level:(topLevel at:(var "StepOverVia")))
)

(define "StepOverPieceIsNuak1"
    (or {
        (= "StepOverPiece" (id "LudecletiNuak1" Mover))
        (= "StepOverPiece" (id "DelunletiNuak1" Mover))
    })
)

(define "StepOverPieceIsKauk2"
    (or {
        (= "StepOverPiece" (id "LudecletiKauk2" Mover))
        (= "StepOverPiece" (id "DelunletiKauk2" Mover))
    })
)

(define "StepOverPieceIsGua2"
    (or {
        (= "StepOverPiece" (id "LudecletiGua2" Mover))
        (= "StepOverPiece" (id "DelunletiGua2" Mover))
    })
)

(define "StepOverPieceIsKaun1"
    (or {
        (= "StepOverPiece" (id "LudecletiKaun1" Mover))
        (= "StepOverPiece" (id "DelunletiKaun1" Mover))
    })
)

(define "StepOverPieceIsDau2"
    (or {
        (= "StepOverPiece" (id "LudecletiDau2" Mover))
        (= "StepOverPiece" (id "DelunletiDau2" Mover))
    })
)

(define "StepOverPieceIsMaun1"
    (or {
        (= "StepOverPiece" (id "LudecletiMaun1" Mover))
        (= "StepOverPiece" (id "DelunletiMaun1" Mover))
    })
)

(define "StepOverPieceIsKua2"
    (or {
        (= "StepOverPiece" (id "LudecletiKua2" Mover))
        (= "StepOverPiece" (id "DelunletiKua2" Mover))
    })
)

(define "StepOverPieceIsTuk2"
    (or {
        (= "StepOverPiece" (id "LudecletiTuk2" Mover))
        (= "StepOverPiece" (id "DelunletiTuk2" Mover))
    })
)

(define "StepOverPieceIsUai1"
    (or {
        (= "StepOverPiece" (id "LudecletiUai1" Mover))
        (= "StepOverPiece" (id "DelunletiUai1" Mover))
    })
)

(define "StepOverPieceIsIo"
    (or {
        (= "StepOverPiece" (id "LudecletiIo" Mover))
        (= "StepOverPiece" (id "DelunletiIo" Mover))
    })
)

(define "NoOccupiedBetweenStepOverFinish"
    (= 0 (count Sites in:(intersection (sites Between from:(var "StepOverVia") to:#1) (sites Occupied by:All))))
)

(define "HasStepOverFinish"
    (>
        (count Sites in:(difference #1 (union {(sites Occupied by:Mover) (sites Occupied by:Neutral) (sites {(from)})})))
        0
    )
)

(define "HasTam2StepOverFinish"
    (or {
        (is In (from) #1)
        (>
            (count Sites in:(difference #1 (sites Occupied by:All)))
            0
        )
    })
)

(define "AnyPreStepOverFinish"
    (> (count Sites in:(difference #1 (union {(sites Occupied by:Mover) (sites Occupied by:Neutral) (sites {(from)})}))) 0)
)

(define "PreAroundStepOverFinish"
    (sites Direction from:(to) #1 distance:1)
)

(define "PreSlideStepOverFinish"
    (sites Direction from:(to) #1 stop:(is Occupied (to)) stopIncluded:True distance:(count Rows))
)

(define "PreExact2StepOverFinish"
    (difference (sites Direction from:(to) #1 distance:2) (sites Direction from:(to) #1 distance:1))
)

(define "PreMaun1HueStepOverFinish"
    (difference (sites Direction from:(to) Diagonal distance:(count Rows)) (sites Direction from:(to) Diagonal distance:1))
)

(define "HasNuak1StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" (union {("PreSlideStepOverFinish" (directions {Forward Backward} of:All)) ("PreAroundStepOverFinish" (directions {Leftward Rightward} of:All)) ("PreExact2StepOverFinish" (directions {Leftward Rightward} of:All))}))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" (directions Forward of:All)))
    )
)

(define "HasKauk2StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" (union {("PreAroundStepOverFinish" Orthogonal) ("PreExact2StepOverFinish" (directions Forward of:All))}))
        ("AnyPreStepOverFinish" ("PreAroundStepOverFinish" (directions Forward of:All)))
    )
)

(define "HasGua2StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" Diagonal))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" Orthogonal))
    )
)

(define "HasKaun1StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreExact2StepOverFinish" Diagonal))
        ("AnyPreStepOverFinish" ("PreExact2StepOverFinish" Orthogonal))
    )
)

(define "HasDau2StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" Diagonal))
        ("AnyPreStepOverFinish" ("PreAroundStepOverFinish" Diagonal))
    )
)

(define "HasMaun1StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" "PreMaun1HueStepOverFinish")
        ("AnyPreStepOverFinish" ("PreExact2StepOverFinish" Diagonal))
    )
)

(define "HasKua2StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" Orthogonal))
        ("AnyPreStepOverFinish" (union {("PreSlideStepOverFinish" (directions {Forward Backward} of:All)) ("PreAroundStepOverFinish" (directions {Leftward Rightward} of:All))}))
    )
)

(define "HasTuk2StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreSlideStepOverFinish" All))
        ("AnyPreStepOverFinish" (union {("PreSlideStepOverFinish" (directions {Leftward Rightward} of:All)) ("PreAroundStepOverFinish" (directions {Forward Backward} of:All))}))
    )
)

(define "HasUai1StepOverFinishFromVia"
    (if ("InTamHue" (to))
        ("AnyPreStepOverFinish" ("PreAroundStepOverFinish" All))
        ("AnyPreStepOverFinish" ("PreAroundStepOverFinish" (directions {Forward Backward Leftward Rightward FL FR} of:All)))
    )
)

(define "HasAnyStepOverFinishFromVia"
    (if "MovingPieceIsNuak1"
        "HasNuak1StepOverFinishFromVia"
        (if "MovingPieceIsKauk2"
            "HasKauk2StepOverFinishFromVia"
            (if "MovingPieceIsGua2"
                "HasGua2StepOverFinishFromVia"
                (if "MovingPieceIsKaun1"
                    "HasKaun1StepOverFinishFromVia"
                    (if "MovingPieceIsDau2"
                        "HasDau2StepOverFinishFromVia"
                        (if "MovingPieceIsMaun1"
                            "HasMaun1StepOverFinishFromVia"
                            (if "MovingPieceIsKua2"
                                "HasKua2StepOverFinishFromVia"
                                (if "MovingPieceIsTuk2"
                                    "HasTuk2StepOverFinishFromVia"
                                    (if "MovingPieceIsUai1"
                                        "HasUai1StepOverFinishFromVia"
                                        (if "MovingPieceIsIo"
                                            ("AnyPreStepOverFinish" ("PreAroundStepOverFinish" All))
                                            False
                                        )
                                    )
                                )
                            )
                        )
                    )
                )
            )
        )
    )
)

(define "AroundStepOverFinish"
    (sites Around (to) #1)
)

(define "LineStepOverFinish"
    (sites {(ahead (to) (directions Cell from:(from) to:(to)))})
)

(define "SlideStepOverFinish"
    (sites Direction from:(to) #1 stop:(is Occupied (to)) stopIncluded:True distance:(count Rows))
)

(define "Exact2StepOverFinish"
    (difference (sites Direction from:(to) #1 distance:2) (sites Direction from:(to) #1 distance:1))
)

(define "Maun1HueStepOverFinish"
    (difference (sites Direction from:(to) Diagonal distance:(count Rows)) (sites Direction from:(to) Diagonal distance:1))
)

(define "FinishStepOver"
    ("WithWaterEntryCheck"
        (move
            (from (var "StepOverVia") level:(topLevel at:(var "StepOverVia")))
            (to #1 if:(and {
                ("CanLandAt" (to))
                (!= (to) (var "StepOverOrigin"))
                ("NoOccupiedBetweenStepOverFinish" (to))
            }) "CapturePiece")
            (then
                (and {
                    (set Var "StepOverPending" 0)
                    (set Var "StepOverPips" (- 0 1))
                    "ClearLastTam2Move"
                })
            )
        )
    )
)

(define "FinishStepOverHop"
    ("WithWaterEntryCheck"
        (move
            (from (var "StepOverVia") level:(topLevel at:(var "StepOverVia")))
            (to #1 if:(and {
                ("CanLandAt" (to))
                (!= (to) (var "StepOverOrigin"))
            }) "CapturePiece")
            (then
                (and {
                    (set Var "StepOverPending" 0)
                    (set Var "StepOverPips" (- 0 1))
                    "ClearLastTam2Move"
                })
            )
        )
    )
)

(define "FinishStepOverStep"
    ("FinishStepOver" (sites Direction from:(var "StepOverVia") #1 distance:1))
)

(define "FinishStepOverDirection"
    ("FinishStepOver" (sites {(ahead (var "StepOverVia") (directions Cell from:(var "StepOverOrigin") to:(var "StepOverVia")))}))
)

(define "FinishStepOverSlide"
    (move Select
        (from (sites Direction from:(var "StepOverVia") #1 distance:1))
        (then
            (and {
                (set Var "StepOverDirection" (last From))
                (set Var "StepOverPips" (- 0 1))
                (set Var "StepOverPending" (+ 100 (var "StepOverPending")))
                (moveAgain)
            })
        )
    )
)

(define "FinishStepOverSlideAs"
    (move Select
        (from (sites Direction from:(var "StepOverVia") #1 distance:1))
        (then
            (and {
                (set Var "StepOverDirection" (last From))
                (set Var "StepOverPips" (- 0 1))
                (set Var "StepOverPending" #2)
                (moveAgain)
            })
        )
    )
)

(define "CancelStepOver"
    (move
        (from (var "StepOverVia") level:(topLevel at:(var "StepOverVia")))
        (to (var "StepOverOrigin"))
        (then
            (and {
                (set Var "StepOverPending" 0)
                (set Var "StepOverPips" (- 0 1))
                "ClearLastTam2Move"
            })
        )
    )
)

(define "FinishOrCancelStepOver"
    (priority
        #1
        "CancelStepOver"
    )
)

(define "FinishStepOverNuak1"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver"
            (or {
                ("FinishStepOverSlideAs" (directions {Forward Backward} of:All) 109)
                ("FinishStepOverStep" (directions {Leftward Rightward} of:All))
                ("FinishStepOverExact2" (directions {Leftward Rightward} of:All))
            })
        )
        ("FinishOrCancelStepOver" ("FinishStepOverSlideAs" (directions Forward of:All) 111))
    )
)

(define "FinishStepOverKauk2"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver"
            (or {
                ("FinishStepOverStep" Orthogonal)
                ("FinishStepOverExact2" (directions Forward of:All))
            })
        )
        ("FinishOrCancelStepOver" ("FinishStepOverStep" (directions Forward of:All)))
    )
)

(define "FinishStepOverGua2"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver" ("FinishStepOverSlideAs" Diagonal 108))
        ("FinishOrCancelStepOver" ("FinishStepOverSlideAs" Orthogonal 107))
    )
)

(define "FinishStepOverKaun1"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver" ("FinishStepOverExact2" Diagonal))
        ("FinishOrCancelStepOver" ("FinishStepOverExact2Hop" Orthogonal))
    )
)

(define "FinishStepOverDau2"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver" ("FinishStepOverSlideAs" Diagonal 108))
        ("FinishOrCancelStepOver" ("FinishStepOverStep" Diagonal))
    )
)

(define "FinishStepOverMaun1"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver" "FinishStepOverMaun1Hue")
        ("FinishOrCancelStepOver" ("FinishStepOverExact2Hop" Diagonal))
    )
)

(define "FinishStepOverKua2"
    (if ("InTamHue" (var "StepOverVia"))
        ("FinishOrCancelStepOver" ("FinishStepOverSlideAs" Orthogonal 107))
        ("FinishOrCancelStepOver"
            (or {
                ("FinishStepOverSlideAs" (directions {Forward Backward} of:All) 109)
                ("FinishStepOverStep" (directions {Leftward Rightward} of:All))
            })
        )
    )
)

(define "FinishStepOverTuk2"
    (if ("InTamHue" (var "StepOverVia"))
