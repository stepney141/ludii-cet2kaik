                    (difference
                        (sites Direction
                            from:(var "StepOverVia")
                            (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                            distance:2
                        )
                        (sites Direction
                            from:(var "StepOverVia")
                            (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                            distance:1
                        )
                    )
                    (sites Direction
                        from:(var "StepOverVia")
                        (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                        distance:(var "StepOverPips")
                    )
                )
            )
            ("FinishStepOver"
                (difference
                    (sites Direction
                        from:(var "StepOverVia")
                        (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                        stop:(is Occupied (to))
                        stopIncluded:True
                        distance:(var "StepOverPips")
                    )
                    (sites Direction
                        from:(var "StepOverVia")
                        (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                        distance:2
                    )
                )
            )
            "CancelStepOver"
        })
