        (or {
            ("SlideCapture" (directions Forward of:All))
            ("StepModeChoice" (sites Direction from:(from) (directions Forward of:All) stop:(is Occupied (to)) stopIncluded:True) 11 ("SlideStepOverFinish" (directions Forward of:All)))
