)

(define "RoleMaun1Gua2Kauk2"
    (if ("OneEachThreeWithIo" #1 ("Kauk2Count" #1) ("Gua2Count" #1) ("Maun1Count" #1))
        (+ 5 (if ("SameColourThree" #1 "LudecletiKauk2" "LudecletiGua2" "LudecletiMaun1" "DelunletiKauk2" "DelunletiGua2" "DelunletiMaun1") 2 0))
        0
    )
)

(define "RoleVehicleLine"
    (if ("OneEachThreeWithIo" #1 ("Nuak1Count" #1) ("Kaun1Count" #1) ("Maun1Count" #1))
        (+ 5 (if ("SameColourThree" #1 "LudecletiNuak1" "LudecletiKaun1" "LudecletiMaun1" "DelunletiNuak1" "DelunletiKaun1" "DelunletiMaun1") 2 0))
        0
    )
)

(define "RoleIo" (if (>= ("IoCount" #1) 1) 5 0))

(define "RoleBeasts"
    (if ("OneEachTwoWithIo" #1 ("Dau2Count" #1) ("Maun1Count" #1))
        (+ 3 (if ("SameColourTwo" #1 "LudecletiDau2" "LudecletiMaun1" "DelunletiDau2" "DelunletiMaun1") 2 0))
        0
    )
)

(define "RoleUai1TwoKauk2s"
    (if ("OneAndTwoWithIo" #1 ("Uai1Count" #1) ("Kauk2Count" #1))
        (+ 3 (if ("SameColourUai1TwoKauk2s" #1) 2 0))
        0
    )
)

(define "RoleKaun1TwoKauk2s"
    (if ("OneAndTwoWithIo" #1 ("Kaun1Count" #1) ("Kauk2Count" #1))
        (+ 3 (if ("SameColourKaun1TwoKauk2s" #1) 2 0))
        0
    )
)

(define "RoleFiveKauk2s"
    (if ("FiveSameKindWithIo" #1 ("Kauk2Count" #1))
        (+ 3 (if ("SameColourFiveKauk2s" #1) 2 0))
        0
    )
)

(define "RoleScoreA" (+ ("RoleAllKinds" #1) ("RoleKua2Line" #1)))
(define "RoleScoreB" (+ ("RoleCoreThree" #1) ("RoleMaun1Gua2Kauk2" #1)))
(define "RoleScoreC" (+ ("RoleVehicleLine" #1) ("RoleIo" #1)))
(define "RoleScoreD" (+ ("RoleBeasts" #1) ("RoleUai1TwoKauk2s" #1)))
(define "RoleScoreE" (+ ("RoleKaun1TwoKauk2s" #1) ("RoleFiveKauk2s" #1)))
(define "RoleScore" (+ (+ ("RoleScoreA" #1) ("RoleScoreB" #1)) (+ (+ ("RoleScoreC" #1) ("RoleScoreD" #1)) ("RoleScoreE" #1))))

(define "CurrentClaim"
    (* (if (< (var "SeasonRate") 1) 1 (var "SeasonRate")) (+ ("RoleScore" #1) #2))
)

(define "ClaimTransfer"
    (if (> (var "PendingClaim") 0)
        (min (var "PendingClaim") (score #2))
        (- 0 (min (- 0 (var "PendingClaim")) (score #1)))
    )
)

(define "ApplyClaimTransfer"
    (set Var "ScoreTransfer" ("ClaimTransfer" #1 #2)
        (then
            (set Score #1 (+ (score #1) (var "ScoreTransfer"))
                (then
                    (set Score #2 (- (score #2) (var "ScoreTransfer"))
                        (then "AfterClaimTransfer")
                    )
                )
            )
        )
    )
)

(define "AfterClaimTransfer"
    (set Var "StartNextSeason" (if "ShouldStartNextSeason" 1 0)
        (then
            (and {
                "FinishSeason"
                (if (= (var "StartNextSeason") 1) ("ResetSeason"))
            })
        )
    )
)

(define "ClearDeclarationPending"
    (set Var "DeclarationPending" 0)
)

(define "AfterMoveDeclarationCheck"
    (if (is Mover P1)
        (if (or {
                (> ("RoleScore" P1) (var "KnownRoleScoreP1"))
                (= (var "NewSituationRoleP1") 1)
            })
            (and {
                (set Var "DeclarationPending" 1)
                (moveAgain)
            })
            (and {
                (set Var "KnownRoleScoreP1" ("RoleScore" P1))
                "ClearDeclarationPending"
            })
        )
        (if (or {
                (> ("RoleScore" P2) (var "KnownRoleScoreP2"))
                (= (var "NewSituationRoleP2") 1)
            })
            (and {
                (set Var "DeclarationPending" 2)
                (moveAgain)
            })
            (and {
                (set Var "KnownRoleScoreP2" ("RoleScore" P2))
                "ClearDeclarationPending"
            })
        )
    )
)

(define "DeclarationChoice"
    (if (is Mover P1)
        (or {"EndSeasonDeclarationP1" "ContinueDeclarationP1"})
        (or {"EndSeasonDeclarationP2" "ContinueDeclarationP2"})
    )
)

(define "EndSeasonDeclarationP1"
    (move Select
        (from (handSite P1 30))
        (then
            (set Var "PendingClaim" ("CurrentClaim" P1 (var "SituationRoleScoreP1"))
                (then
                    (and {
                        "ClearLastTam2Move"
                        "ClearDeclarationPending"
                        ("ApplyClaimTransfer" P1 P2)
                    })
                )
            )
        )
    )
)

(define "EndSeasonDeclarationP2"
    (move Select
        (from (handSite P2 30))
        (then
            (set Var "PendingClaim" ("CurrentClaim" P2 (var "SituationRoleScoreP2"))
                (then
                    (and {
                        "ClearLastTam2Move"
                        "ClearDeclarationPending"
                        ("ApplyClaimTransfer" P2 P1)
                    })
                )
            )
        )
    )
)

(define "ContinueDeclarationP1"
    (move Select
        (from (handSite P1 31))
        (then
            (and {
                "ClearLastTam2Move"
                "ClearDeclarationPending"
                (set Var "KnownRoleScoreP1" ("RoleScore" P1))
                (set Var "NewSituationRoleP1" 0)
                (set Var "SeasonRate" (* 2 (if (< (var "SeasonRate") 1) 1 (var "SeasonRate"))))
            })
        )
    )
)

(define "ContinueDeclarationP2"
    (move Select
        (from (handSite P2 31))
        (then
            (and {
                "ClearLastTam2Move"
                "ClearDeclarationPending"
                (set Var "KnownRoleScoreP2" ("RoleScore" P2))
                (set Var "NewSituationRoleP2" 0)
                (set Var "SeasonRate" (* 2 (if (< (var "SeasonRate") 1) 1 (var "SeasonRate"))))
            })
        )
    )
)

(define "FinishSeason"
    (and {
        (set Var "Season" (+ 1 (var "Season")))
        (set Value P1 1)
        (set Value P2 1)
        (set Var "KnownRoleScoreP1" 0)
        (set Var "KnownRoleScoreP2" 0)
        (set Var "SituationRoleScoreP1" 0)
        (set Var "SituationRoleScoreP2" 0)
        (set Var "NewSituationRoleP1" 0)
        (set Var "NewSituationRoleP2" 0)
        (set Var "SeasonRate" 1)
        (set Var "PendingClaim" 0)
        (set Var "ScoreTransfer" 0)
        "ClearLastTam2Move"
        (set Var "Tam2Pending" 0)
        (set Var "Tam2Futile" 0)
        (set Var "StepOverPending" 0)
        (set Var "StepOverTurn" (- 0 1))
        (set Var "StepOverOrigin" (- 0 1))
        (set Var "StepOverVia" (- 0 1))
        (set Var "StepOverDirection" (- 0 1))
        (set Var "StepOverPips" (- 0 1))
        (set Var "StepOverMode" 0)
        (set Var "StepOverArmedOrigin" (- 0 1))
        "ClearDeclarationPending"
    })
)

(define "ShouldStartNextSeason"
    (and {
        (< (+ 1 (var "Season")) <Seasons:num>)
        (< (score P1) 40)
        (< (score P2) 40)
        (> (score P1) 0)
        (> (score P2) 0)
    })
)

(define "DeclarationMarkers"
    (and {
        (add (piece (id "TaXot1Marker" Neutral)) (to (handSite P1 30)))
        (add (piece (id "TyMok1Marker" Neutral)) (to (handSite P1 31)))
        (add (piece (id "TaXot1Marker" Neutral)) (to (handSite P2 30)))
        (add (piece (id "TyMok1Marker" Neutral)) (to (handSite P2 31)))
    })
)

(define "InitialPosition"
    (and {
        (add (piece (id "DelunletiKua2" P2)) (to (sites "KA")))
        (add (piece (id "DelunletiMaun1" P2)) (to (sites "LA")))
        (add (piece (id "DelunletiKaun1" P2)) (to (sites "NA")))
        (add (piece (id "DelunletiUai1" P2)) (to (sites "TA")))
        (add (piece (id "LudecletiIo" P2)) (to (sites "ZA")))
        (add (piece (id "LudecletiUai1" P2)) (to (sites "XA")))
        (add (piece (id "LudecletiKaun1" P2)) (to (sites "CA")))
        (add (piece (id "LudecletiMaun1" P2)) (to (sites "MA")))
        (add (piece (id "LudecletiKua2" P2)) (to (sites "PA")))
        (add (piece (id "LudecletiTuk2" P2)) (to (sites "KE")))
        (add (piece (id "LudecletiGua2" P2)) (to (sites "LE")))
        (add (piece (id "LudecletiDau2" P2)) (to (sites "TE")))
        (add (piece (id "DelunletiDau2" P2)) (to (sites "XE")))
        (add (piece (id "DelunletiGua2" P2)) (to (sites "ME")))
        (add (piece (id "DelunletiTuk2" P2)) (to (sites "PE")))
        (add (piece (id "DelunletiKauk2" P2)) (to (sites "KI")))
        (add (piece (id "LudecletiKauk2" P2)) (to (sites "LI")))
        (add (piece (id "DelunletiKauk2" P2)) (to (sites "NI")))
        (add (piece (id "LudecletiKauk2" P2)) (to (sites "TI")))
        (add (piece (id "LudecletiNuak1" P2)) (to (sites "ZI")))
        (add (piece (id "LudecletiKauk2" P2)) (to (sites "XI")))
        (add (piece (id "DelunletiKauk2" P2)) (to (sites "CI")))
        (add (piece (id "LudecletiKauk2" P2)) (to (sites "MI")))
        (add (piece (id "DelunletiKauk2" P2)) (to (sites "PI")))
        (add (piece (id "Tam2" Neutral)) (to (sites "ZO")))
        (add (piece (id "DelunletiKauk2" P1)) (to (sites "KAI")))
