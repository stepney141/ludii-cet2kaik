                )
            )
        )
    )
)

(define "FinishStepOverDirectedSlide"
    (if (< (var "StepOverPips") 0)
        "ThrowStepOverSticks"
        (or {
            ("FinishStepOver"
                (sites Direction
                    from:(var "StepOverVia")
                    (directions Cell from:(var "StepOverVia") to:(var "StepOverDirection"))
                    stop:(is Occupied (to))
                    stopIncluded:True
                    distance:(var "StepOverPips")
                )
            )
            "CancelStepOver"
        })
    )
)

(define "FinishStepOverExact2"
    ("FinishStepOver" (difference (sites Direction from:(var "StepOverVia") #1 distance:2) (sites Direction from:(var "StepOverVia") #1 distance:1)))
)

(define "FinishStepOverExact2Hop"
    ("FinishStepOverHop" (difference (sites Direction from:(var "StepOverVia") #1 distance:2) (sites Direction from:(var "StepOverVia") #1 distance:1)))
)

(define "FinishStepOverMaun1Hue"
    (move Select
        (from (sites Direction from:(var "StepOverVia") Diagonal distance:1))
        (then
            (and {
                (set Var "StepOverDirection" (last From))
                (set Var "StepOverPips" (- 0 1))
                (set Var "StepOverPending" 116)
                (moveAgain)
            })
        )
    )
)

(define "FinishStepOverDirectedMaun1Hue"
