)

(define "AllKindsRole"
    (and {
        (>= ("Nuak1Count" #1) 1)
        (>= ("Kauk2Count" #1) 1)
        (>= ("Gua2Count" #1) 1)
        (>= ("Kaun1Count" #1) 1)
        (>= ("Dau2Count" #1) 1)
        (>= ("Maun1Count" #1) 1)
        (>= ("Kua2Count" #1) 1)
        (>= ("Tuk2Count" #1) 1)
        (>= ("Uai1Count" #1) 1)
        (>= ("IoCount" #1) 1)
    })
)

(define "AllKindsSameColour"
    (or {
        (and {
            (>= ("HC" #1 "LudecletiNuak1") 1) (>= ("HC" #1 "LudecletiKauk2") 1)
            (>= ("HC" #1 "LudecletiGua2") 1) (>= ("HC" #1 "LudecletiKaun1") 1)
            (>= ("HC" #1 "LudecletiDau2") 1) (>= ("HC" #1 "LudecletiMaun1") 1)
            (>= ("HC" #1 "LudecletiKua2") 1) (>= ("HC" #1 "LudecletiTuk2") 1)
            (>= ("HC" #1 "LudecletiUai1") 1) (>= ("HC" #1 "LudecletiIo") 1)
        })
        (and {
            (>= ("HC" #1 "DelunletiNuak1") 1) (>= ("HC" #1 "DelunletiKauk2") 1)
            (>= ("HC" #1 "DelunletiGua2") 1) (>= ("HC" #1 "DelunletiKaun1") 1)
            (>= ("HC" #1 "DelunletiDau2") 1) (>= ("HC" #1 "DelunletiMaun1") 1)
            (>= ("HC" #1 "DelunletiKua2") 1) (>= ("HC" #1 "DelunletiTuk2") 1)
            (>= ("HC" #1 "DelunletiUai1") 1) (>= ("HC" #1 "DelunletiIo") 1)
        })
    })
)

(define "AllFive"
    (and {(>= ("HC" #1 #2) 1) (>= ("HC" #1 #3) 1) (>= ("HC" #1 #4) 1) (>= ("HC" #1 #5) 1) (>= ("HC" #1 #6) 1)})
)

(define "AllFiveWithIo"
    (>= (+ (+ (+ ("One" ("HC" #1 #2)) ("One" ("HC" #1 #3))) (+ ("One" ("HC" #1 #4)) ("One" ("HC" #1 #5)))) (+ ("One" ("HC" #1 #6)) ("HC" #1 #7))) 5)
)

(define "SameColourThree"
