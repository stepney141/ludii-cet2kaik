(define "MarkFirstTam2MoveStarted"
    (and {
        (set Var "Tam2Origin" (last From))
        (if
            ("OpponentMovedTam2LastTurn")
            (and {(set Var "Tam2Futile" 1) ("AddSituationRoleMover" -3)})
            (set Var "Tam2Futile" 0)
        )
    })
)

(define "StartSecondTam2Move"
    (and {
        "MarkFirstTam2MoveStarted"
        (set Var "Tam2Pending" 1)
        (moveAgain)
    })
)

(define "FinishSecondTam2Move"
    (and {
        (if (and {(= (last To) (var "Tam2Origin")) (!= (var "Tam2Futile") 1)}) ("AddSituationRoleMover" -3))
        (set Var "Tam2Pending" 0)
        (set Var "Tam2Futile" 0)
        (set Var "LastTam2Mover" (mover))
    })
)

(define "BeginTam2StepOver"
    (move
        (from (where "Tam2" Neutral))
        (to #1 if:(and {
            (!= (var "StepOverTurn") (count Turns))
            (is Occupied (to))
            ("HasTam2StepOverFinish" #3)
        }))
        stack:True
        (then
            (and {
                (set Var "StepOverOrigin" (last From))
                (set Var "StepOverVia" (last To))
                (set Var "StepOverPending" #2)
                (set Var "StepOverTurn" (count Turns))
                #4
                (moveAgain)
            })
        )
    )
)

(define "FinishTam2StepOver"
    (move
        (from (var "StepOverVia") level:(topLevel at:(var "StepOverVia")))
        (to #1 if:(is Empty (to)))
        (then
            (and {
                (set Var "StepOverPending" 0)
                #2
            })
        )
    )
)

(define "FinishFirstTam2StepOver"
    ("FinishTam2StepOver"
        (sites Around (var "StepOverVia") All)
        "FinishSecondTam2Move"
    )
)

(define "OpponentMovedTam2LastTurn"
    (and {
        (!= (var "LastTam2Mover") 0)
        (!= (var "LastTam2Mover") (mover))
    })
)

(define "Tam2Move"
    (if
        (= (var "Tam2Pending") 0)
        (or {
            (move Step
                (from (where "Tam2" Neutral))
                All
                (to if:(is Empty (to)))
                (then "StartSecondTam2Move")
            )
            ("BeginTam2StepOver" (sites Around (where "Tam2" Neutral) All) 21 (sites Around (to) All) "MarkFirstTam2MoveStarted")
        })
        (or {
            (move Step
                (from (where "Tam2" Neutral))
                All
                (to if:(is Empty (to)))
                (then "FinishSecondTam2Move")
            )
        })
    )
)

(define "IsNuak1AtLastTo"
    (or {
        (= (what at:(last To)) (id "LudecletiNuak1" Mover))
        (= (what at:(last To)) (id "DelunletiNuak1" Mover))
    })
)

(define "WaterEntryAllowed"
    (or {
        (not (is In (last To) (sites "TamNua")))
        ("IsNuak1AtLastTo")
        (= (what at:(last To)) (id "Tam2" Neutral))
        "WaterEntryStartInWater"
        (is In (last From) (sites Hand Mover))
        (>= (count Pips) 3)
    })
)

(define "NeedsWaterRoll"
    (and {
        (is In (last To) (sites "TamNua"))
        (not ("IsNuak1AtLastTo"))
        (!= (what at:(last To)) (id "Tam2" Neutral))
        (not "WaterEntryStartInWater")
        (not (is In (last From) (sites Hand Mover)))
    })
)

(define "CetkaikMove"
    (if (> (var "StepOverPending") 0)
        "FinishPendingStepOver"
        (if "ArmedStepOverMode"
            (priority
                (forEach Piece)
                "CancelArmedStepOver"
            )
            (if (= (var "Tam2Pending") 1)
                "Tam2Move"
                (or {
                    (forEach Piece)
                    "ArmStepOver"
                    "Tam2Move"
                    (move
                        (from (sites Occupied by:Mover container:"Hand"))
                        (to (sites Empty))
                        (then "ClearLastTam2Move")
                    )
                })
            )
        )
    )
)

(define "AfterCetkaikMove"
    (if (> (var "StepOverPending") 0)
        "ClearDeclarationPending"
        (if "ArmedStepOverMode"
            "ClearDeclarationPending"
            (if (= (var "StepOverMode") 2)
                (and {
                    "ClearStepOverMode"
                    "ClearDeclarationPending"
                })
                "AfterMoveDeclarationCheck"
            )
        )
    )
)

(define "HC" (count Pieces in:(sites Occupied by:#1 container:"Hand" components:{#2})))

(define "Nuak1Count" (+ ("HC" #1 "LudecletiNuak1") ("HC" #1 "DelunletiNuak1")))
(define "Kauk2Count" (+ ("HC" #1 "LudecletiKauk2") ("HC" #1 "DelunletiKauk2")))
(define "Gua2Count" (+ ("HC" #1 "LudecletiGua2") ("HC" #1 "DelunletiGua2")))
(define "Kaun1Count" (+ ("HC" #1 "LudecletiKaun1") ("HC" #1 "DelunletiKaun1")))
(define "Dau2Count" (+ ("HC" #1 "LudecletiDau2") ("HC" #1 "DelunletiDau2")))
(define "Maun1Count" (+ ("HC" #1 "LudecletiMaun1") ("HC" #1 "DelunletiMaun1")))
(define "Kua2Count" (+ ("HC" #1 "LudecletiKua2") ("HC" #1 "DelunletiKua2")))
(define "Tuk2Count" (+ ("HC" #1 "LudecletiTuk2") ("HC" #1 "DelunletiTuk2")))
(define "Uai1Count" (+ ("HC" #1 "LudecletiUai1") ("HC" #1 "DelunletiUai1")))
(define "IoCount" (+ ("HC" #1 "LudecletiIo") ("HC" #1 "DelunletiIo")))

(define "One" (if (>= #1 1) 1 0))
(define "CapTwo" (if (>= #1 2) 2 #1))
(define "CapFive" (if (>= #1 5) 5 #1))

(define "OneEachFiveWithIo"
    (>= (+ (+ (+ ("One" #2) ("One" #3)) (+ ("One" #4) ("One" #5))) (+ ("One" #6) ("IoCount" #1))) 5)
)

(define "OneEachThreeWithIo"
    (>= (+ (+ ("One" #2) ("One" #3)) (+ ("One" #4) ("IoCount" #1))) 3)
)

(define "OneEachTwoWithIo"
    (>= (+ (+ ("One" #2) ("One" #3)) ("IoCount" #1)) 2)
)

(define "OneAndTwoWithIo"
    (>= (+ (+ ("One" #2) ("CapTwo" #3)) ("IoCount" #1)) 3)
)

(define "FiveSameKindWithIo"
