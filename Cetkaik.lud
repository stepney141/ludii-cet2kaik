(define "RoleAllKinds" (if ("AllKindsRole" #1) (+ 50 (if ("AllKindsSameColour" #1) 2 0)) 0))

(define "RoleKua2Line"
    (if ("OneEachFiveWithIo" #1 ("Kauk2Count" #1) ("Gua2Count" #1) ("Uai1Count" #1) ("Kua2Count" #1) ("Tuk2Count" #1))
        (+ 10 (if (or {
                ("AllFiveWithIo" #1 "LudecletiKauk2" "LudecletiGua2" "LudecletiUai1" "LudecletiKua2" "LudecletiTuk2" "LudecletiIo")
                ("AllFiveWithIo" #1 "DelunletiKauk2" "DelunletiGua2" "DelunletiUai1" "DelunletiKua2" "DelunletiTuk2" "DelunletiIo")
            }) 2 0))
        0
    )
)

(define "RoleCoreThree"
    (if ("OneEachThreeWithIo" #1 ("Kua2Count" #1) ("Tuk2Count" #1) ("Uai1Count" #1))
        (+ 7 (if ("SameColourThree" #1 "LudecletiKua2" "LudecletiTuk2" "LudecletiUai1" "DelunletiKua2" "DelunletiTuk2" "DelunletiUai1") 2 0))
        0
