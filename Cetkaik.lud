        (show Symbol "assets/cetkaik/cerke_diag_backslash.svg" Cell (union {(sites "NI") (sites "TU") (sites "XY") (sites "CAI") (sites "ZO")}) fillColour:(colour Black) edgeColour:(colour Black) scale:1.0)
        (show Symbol "assets/cetkaik/cerke_diag_slash.svg" Cell (union {(sites "CI") (sites "XU") (sites "TY") (sites "NAI") (sites "ZO")}) fillColour:(colour Black) edgeColour:(colour Black) scale:1.0)

