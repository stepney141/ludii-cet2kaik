        (regions "LAU" (sites {"B2"}))
        (regions "NAU" (sites {"C2"}))
        (regions "TAU" (sites {"D2"}))
        (regions "ZAU" (sites {"E2"}))
        (regions "XAU" (sites {"F2"}))
        (regions "CAU" (sites {"G2"}))
        (regions "MAU" (sites {"H2"}))
        (regions "PAU" (sites {"I2"}))
        (regions "KIA" (sites {"A1"}))
        (regions "LIA" (sites {"B1"}))
        (regions "NIA" (sites {"C1"}))
        (regions "TIA" (sites {"D1"}))
        (regions "ZIA" (sites {"E1"}))
        (regions "XIA" (sites {"F1"}))
        (regions "CIA" (sites {"G1"}))
        (regions "MIA" (sites {"H1"}))
        (regions "PIA" (sites {"I1"}))

        (regions "TamHue" (union {(sites "NI") (sites "CI") (sites "TU") (sites "XU") (sites "ZO") (sites "TY") (sites "XY") (sites "NAI") (sites "CAI")}))
        (regions "TamNua" (union {(sites "ZI") (sites "NO") (sites "TO") (sites "ZO") (sites "XO") (sites "CO") (sites "ZAI")}))
        (regions "TamZo" (union {(sites "ZO")}))
    })
    (rules
        (start {
            (set Score Each 20)
            (place "DelunletiKua22" (sites "KA"))
            (place "DelunletiMaun12" (sites "LA"))
            (place "DelunletiKaun12" (sites "NA"))
            (place "DelunletiUai12" (sites "TA"))
            (place "LudecletiIo2" (sites "ZA"))
            (place "LudecletiUai12" (sites "XA"))
            (place "LudecletiKaun12" (sites "CA"))
            (place "LudecletiMaun12" (sites "MA"))
            (place "LudecletiKua22" (sites "PA"))
            (place "LudecletiTuk22" (sites "KE"))
            (place "LudecletiGua22" (sites "LE"))
            (place "LudecletiDau22" (sites "TE"))
            (place "DelunletiDau22" (sites "XE"))
            (place "DelunletiGua22" (sites "ME"))
            (place "DelunletiTuk22" (sites "PE"))
            (place "DelunletiKauk22" (sites "KI"))
            (place "LudecletiKauk22" (sites "LI"))
            (place "DelunletiKauk22" (sites "NI"))
            (place "LudecletiKauk22" (sites "TI"))
            (place "LudecletiNuak12" (sites "ZI"))
            (place "LudecletiKauk22" (sites "XI"))
            (place "DelunletiKauk22" (sites "CI"))
            (place "LudecletiKauk22" (sites "MI"))
            (place "DelunletiKauk22" (sites "PI"))
            (place "Tam20" (sites "ZO"))
            (place "DelunletiKauk21" (sites "KAI"))
            (place "LudecletiKauk21" (sites "LAI"))
            (place "DelunletiKauk21" (sites "NAI"))
            (place "LudecletiKauk21" (sites "TAI"))
            (place "DelunletiNuak11" (sites "ZAI"))
            (place "LudecletiKauk21" (sites "XAI"))
            (place "DelunletiKauk21" (sites "CAI"))
            (place "LudecletiKauk21" (sites "MAI"))
            (place "DelunletiKauk21" (sites "PAI"))
            (place "DelunletiTuk21" (sites "KAU"))
            (place "DelunletiGua21" (sites "LAU"))
            (place "DelunletiDau21" (sites "TAU"))
            (place "LudecletiDau21" (sites "XAU"))
            (place "LudecletiGua21" (sites "MAU"))
            (place "LudecletiTuk21" (sites "PAU"))
            (place "LudecletiKua21" (sites "KIA"))
            (place "LudecletiMaun11" (sites "LIA"))
            (place "LudecletiKaun11" (sites "NIA"))
            (place "LudecletiUai11" (sites "TIA"))
            (place "DelunletiIo1" (sites "ZIA"))
            (place "DelunletiUai11" (sites "XIA"))
            (place "DelunletiKaun11" (sites "CIA"))
            (place "DelunletiMaun11" (sites "MIA"))
            (place "DelunletiKua21" (sites "PIA"))
            (place "TaXot1Marker0" (handSite P1 30))
            (place "TyMok1Marker0" (handSite P1 31))
            (place "TaXot1Marker0" (handSite P2 30))
            (place "TyMok1Marker0" (handSite P2 31))
        })
        (play
            (if (<= (var "StarterChosen") 0)
                "ChooseStarter"
                (if (and {(= (var "DeclarationPending") (mover)) (= (var "StepOverPending") 0) (= (var "StepOverMode") 0) (= (var "Tam2Pending") 0)})
                    "DeclarationChoice"
                    (do
                        "CetkaikMove"
                        ifAfterwards:(and {"WaterEntryAllowed" "BoardStacksAllowed"})
                        (then "AfterCetkaikMove")
                    )
                )
            )
        )
        (end
            {
                (if
                    (and {
                        (= (var "StepOverPending") 0)
                        (= (var "StepOverMode") 0)
                        (= (var "Tam2Pending") 0)
                        (or {(>= (score P1) 40) (<= (score P2) 0)})
                    })
                    (result P1 Win)
                )
                (if
                    (and {
                        (= (var "StepOverPending") 0)
                        (= (var "StepOverMode") 0)
                        (= (var "Tam2Pending") 0)
                        (or {(>= (score P2) 40) (<= (score P1) 0)})
                    })
                    (result P2 Win)
                )
                (if
                    (and {
                        (= (var "StepOverPending") 0)
                        (= (var "StepOverMode") 0)
                        (= (var "Tam2Pending") 0)
                        (>= (var "Season") <Seasons:num>)
                    })
                    (byScore)
                )
            }
        )
    )
)

(option "Seasons" <Seasons> args:{ <num> } {
    (item "1" <1> "Play 1 season.")
    (item "2" <2> "Play 2 seasons.")
    (item "4" <4> "Play 4 seasons.")*
})

(metadata
    (info {
        (description "Cetkaik, also called Sekkaiku or Cerke, is a 9x9 two-player board game in which players capture pieces, build hands, and score across xot1 seasons.")
        (rules "This implementation follows the standardized Cetkaik rule with the official 9x9 initial position, capture to hand, hand drops, standard and tam2 hue movement, neutral tam2 movement, tam2 water entry casts using five sticks, role scoring with Io as a same-colour wildcard, xot1 season reset, starter selection by both players' five-stick throws with rerolls on ties, and 1, 2, or 4 season options. Stepping-over is implemented for same-line moves, direction-changing one-step continuations, sliding continuations with five-stick distance limits, fixed two-step continuations for jumping pieces, and the tam2 hue Maun1 diagonal continuation that ignores adjacent blockers. Declaration choices are offered after a completed turn when the mover's role score has newly increased or a negative situation role has occurred, and ty mok1 doubles the shared season rate. Gekkou and tam2 return penalties are scored as negative situation roles at xot1.")
        (source "Japan Cetkaik Association, The Standardized Rule of Cetkaik, https://sites.google.com/view/cet2kaik/")
        (version "0.9")
        (credit "Implemented for Ludii from the Japan Cetkaik Association standardized rule pages and sozysozbot/cerke rule summary.")
    })
    (graphics {
        (player Colour P1 (colour White))
        (player Colour P2 (colour LightGrey))
        (show Symbol "square" Cell (sites "TamHue") fillColour:(colour 255 153 88) edgeColour:(colour Black) scale:1.0)
        (show Symbol "square" Cell (sites {"E7" "E6" "C5" "D5" "F5" "G5" "E4" "E3"}) fillColour:(colour 129 199 211) edgeColour:(colour Black) scale:1.0)
        (show Symbol "square" Cell (sites "TamZo") fillColour:(colour 88 116 91) edgeColour:(colour Black) scale:1.0)
        (piece Rename piece:"Die1" "SetDilthDice")
        (piece Rename piece:"Die2" "SetDilthDice")
        (piece Rename piece:"Die3" "SetDilthDice")
        (piece Rename piece:"Die4" "SetDilthDice")
