        (add (piece (id "DelunletiKauk2" P1)) (to (sites "PAI")))
        (add (piece (id "DelunletiTuk2" P1)) (to (sites "KAU")))
        (add (piece (id "DelunletiGua2" P1)) (to (sites "LAU")))
        (add (piece (id "DelunletiDau2" P1)) (to (sites "TAU")))
        (add (piece (id "LudecletiDau2" P1)) (to (sites "XAU")))
        (add (piece (id "LudecletiGua2" P1)) (to (sites "MAU")))
        (add (piece (id "LudecletiTuk2" P1)) (to (sites "PAU")))
        (add (piece (id "LudecletiKua2" P1)) (to (sites "KIA")))
        (add (piece (id "LudecletiMaun1" P1)) (to (sites "LIA")))
        (add (piece (id "LudecletiKaun1" P1)) (to (sites "NIA")))
        (add (piece (id "LudecletiUai1" P1)) (to (sites "TIA")))
        (add (piece (id "DelunletiIo" P1)) (to (sites "ZIA")))
        (add (piece (id "DelunletiUai1" P1)) (to (sites "XIA")))
        (add (piece (id "DelunletiKaun1" P1)) (to (sites "CIA")))
        (add (piece (id "DelunletiMaun1" P1)) (to (sites "MIA")))
        (add (piece (id "DelunletiKua2" P1)) (to (sites "PIA")))
    })
)

(define "ResetSeason"
    (and {
        (forEach Site (sites Occupied by:All container:"Board") (remove (site) count:(size Stack at:(site))))
        (forEach Site (sites Hand P1) (remove (site) count:(size Stack at:(site))))
        (forEach Site (sites Hand P2) (remove (site) count:(size Stack at:(site))))
        (set Var "StarterChosen" 0)
        (set Var "StarterStage" 0)
        (set Var "StarterP1" 0)
        ("InitialPosition")
        "DeclarationMarkers"
        (set Var "StartNextSeason" 0)
        (set NextPlayer (player 1))
    })
)

(game "Cetkaik"
    (players {(player N) (player S)})
    (equipment {
        (board (square 9))
        (hand Each size:32)
        ("StickDice" 5)

        (piece "LudecletiNuak1" Each "Nuak1Move")
        (piece "DelunletiNuak1" Each "Nuak1Move")
        (piece "LudecletiKauk2" Each "Kauk2Move")
        (piece "DelunletiKauk2" Each "Kauk2Move")
        (piece "LudecletiGua2" Each "Gua2Move")
        (piece "DelunletiGua2" Each "Gua2Move")
        (piece "LudecletiKaun1" Each "Kaun1Move")
        (piece "DelunletiKaun1" Each "Kaun1Move")
        (piece "LudecletiDau2" Each "Dau2Move")
        (piece "DelunletiDau2" Each "Dau2Move")
        (piece "LudecletiMaun1" Each "Maun1Move")
        (piece "DelunletiMaun1" Each "Maun1Move")
        (piece "LudecletiKua2" Each "Kua2Move")
        (piece "DelunletiKua2" Each "Kua2Move")
        (piece "LudecletiTuk2" Each "Tuk2Move")
        (piece "DelunletiTuk2" Each "Tuk2Move")
        (piece "LudecletiUai1" Each "Uai1Move")
        (piece "DelunletiUai1" Each "Uai1Move")
        (piece "LudecletiIo" Each "IoMove")
        (piece "DelunletiIo" Each "IoMove")
        (piece "TaXot1Marker" Neutral)
        (piece "TyMok1Marker" Neutral)
        (piece "Tam2" Neutral (move Step All (to if:(is Empty (to)))))

        (map "Where" {
            (pair (id "LudecletiNuak1" P1) (handSite P2 0)) (pair (id "LudecletiNuak1" P2) (handSite P1 0))
            (pair (id "DelunletiNuak1" P1) (handSite P2 1)) (pair (id "DelunletiNuak1" P2) (handSite P1 1))
            (pair (id "LudecletiKauk2" P1) (handSite P2 2)) (pair (id "LudecletiKauk2" P2) (handSite P1 2))
            (pair (id "DelunletiKauk2" P1) (handSite P2 3)) (pair (id "DelunletiKauk2" P2) (handSite P1 3))
            (pair (id "LudecletiGua2" P1) (handSite P2 4)) (pair (id "LudecletiGua2" P2) (handSite P1 4))
            (pair (id "DelunletiGua2" P1) (handSite P2 5)) (pair (id "DelunletiGua2" P2) (handSite P1 5))
            (pair (id "LudecletiKaun1" P1) (handSite P2 6)) (pair (id "LudecletiKaun1" P2) (handSite P1 6))
            (pair (id "DelunletiKaun1" P1) (handSite P2 7)) (pair (id "DelunletiKaun1" P2) (handSite P1 7))
            (pair (id "LudecletiDau2" P1) (handSite P2 8)) (pair (id "LudecletiDau2" P2) (handSite P1 8))
            (pair (id "DelunletiDau2" P1) (handSite P2 9)) (pair (id "DelunletiDau2" P2) (handSite P1 9))
            (pair (id "LudecletiMaun1" P1) (handSite P2 10)) (pair (id "LudecletiMaun1" P2) (handSite P1 10))
            (pair (id "DelunletiMaun1" P1) (handSite P2 11)) (pair (id "DelunletiMaun1" P2) (handSite P1 11))
            (pair (id "LudecletiKua2" P1) (handSite P2 12)) (pair (id "LudecletiKua2" P2) (handSite P1 12))
            (pair (id "DelunletiKua2" P1) (handSite P2 13)) (pair (id "DelunletiKua2" P2) (handSite P1 13))
            (pair (id "LudecletiTuk2" P1) (handSite P2 14)) (pair (id "LudecletiTuk2" P2) (handSite P1 14))
            (pair (id "DelunletiTuk2" P1) (handSite P2 15)) (pair (id "DelunletiTuk2" P2) (handSite P1 15))
            (pair (id "LudecletiUai1" P1) (handSite P2 16)) (pair (id "LudecletiUai1" P2) (handSite P1 16))
            (pair (id "DelunletiUai1" P1) (handSite P2 17)) (pair (id "DelunletiUai1" P2) (handSite P1 17))
            (pair (id "LudecletiIo" P1) (handSite P2 18)) (pair (id "LudecletiIo" P2) (handSite P1 18))
            (pair (id "DelunletiIo" P1) (handSite P2 19)) (pair (id "DelunletiIo" P2) (handSite P1 19))
        })
        (map "Captured" {
            (pair (id "LudecletiNuak1" P1) (id "LudecletiNuak1" P2)) (pair (id "LudecletiNuak1" P2) (id "LudecletiNuak1" P1))
            (pair (id "DelunletiNuak1" P1) (id "DelunletiNuak1" P2)) (pair (id "DelunletiNuak1" P2) (id "DelunletiNuak1" P1))
            (pair (id "LudecletiKauk2" P1) (id "LudecletiKauk2" P2)) (pair (id "LudecletiKauk2" P2) (id "LudecletiKauk2" P1))
            (pair (id "DelunletiKauk2" P1) (id "DelunletiKauk2" P2)) (pair (id "DelunletiKauk2" P2) (id "DelunletiKauk2" P1))
            (pair (id "LudecletiGua2" P1) (id "LudecletiGua2" P2)) (pair (id "LudecletiGua2" P2) (id "LudecletiGua2" P1))
            (pair (id "DelunletiGua2" P1) (id "DelunletiGua2" P2)) (pair (id "DelunletiGua2" P2) (id "DelunletiGua2" P1))
            (pair (id "LudecletiKaun1" P1) (id "LudecletiKaun1" P2)) (pair (id "LudecletiKaun1" P2) (id "LudecletiKaun1" P1))
            (pair (id "DelunletiKaun1" P1) (id "DelunletiKaun1" P2)) (pair (id "DelunletiKaun1" P2) (id "DelunletiKaun1" P1))
            (pair (id "LudecletiDau2" P1) (id "LudecletiDau2" P2)) (pair (id "LudecletiDau2" P2) (id "LudecletiDau2" P1))
            (pair (id "DelunletiDau2" P1) (id "DelunletiDau2" P2)) (pair (id "DelunletiDau2" P2) (id "DelunletiDau2" P1))
            (pair (id "LudecletiMaun1" P1) (id "LudecletiMaun1" P2)) (pair (id "LudecletiMaun1" P2) (id "LudecletiMaun1" P1))
            (pair (id "DelunletiMaun1" P1) (id "DelunletiMaun1" P2)) (pair (id "DelunletiMaun1" P2) (id "DelunletiMaun1" P1))
            (pair (id "LudecletiKua2" P1) (id "LudecletiKua2" P2)) (pair (id "LudecletiKua2" P2) (id "LudecletiKua2" P1))
            (pair (id "DelunletiKua2" P1) (id "DelunletiKua2" P2)) (pair (id "DelunletiKua2" P2) (id "DelunletiKua2" P1))
            (pair (id "LudecletiTuk2" P1) (id "LudecletiTuk2" P2)) (pair (id "LudecletiTuk2" P2) (id "LudecletiTuk2" P1))
            (pair (id "DelunletiTuk2" P1) (id "DelunletiTuk2" P2)) (pair (id "DelunletiTuk2" P2) (id "DelunletiTuk2" P1))
            (pair (id "LudecletiUai1" P1) (id "LudecletiUai1" P2)) (pair (id "LudecletiUai1" P2) (id "LudecletiUai1" P1))
            (pair (id "DelunletiUai1" P1) (id "DelunletiUai1" P2)) (pair (id "DelunletiUai1" P2) (id "DelunletiUai1" P1))
            (pair (id "LudecletiIo" P1) (id "LudecletiIo" P2)) (pair (id "LudecletiIo" P2) (id "LudecletiIo" P1))
            (pair (id "DelunletiIo" P1) (id "DelunletiIo" P2)) (pair (id "DelunletiIo" P2) (id "DelunletiIo" P1))
        })

        (regions "KA" (sites {"A9"}))
        (regions "LA" (sites {"B9"}))
        (regions "NA" (sites {"C9"}))
